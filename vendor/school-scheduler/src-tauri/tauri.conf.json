{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WVCS Scheduler",
  "version": "0.1.0",
  "identifier": "com.wvcs.scheduler",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "WVCS Scheduler",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk5OEQ5OUNGMDQ5REFFNEEKUldSS3JwMEV6NW1ObVNPVm9vSml1MUpNRnNwZEVhYzRJSXVMTUhPSkdxZjdUQ3JTVFNTb3RlcDMK",
      "endpoints": [
        "https://github.com/ChristianInfluence/school-scheduler/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
